# ============================================
# CareerHub Pro - Environment Variables
# ============================================
# Copy this file to .env and update the values

# ============================================
# BACKEND (Django) - Place in /backend/.env
# ============================================
DEBUG=True
SECRET_KEY=your-secure-django-secret-key-here
DATABASE_URL=sqlite:///db.sqlite3

# For PostgreSQL (optional):
# DATABASE_URL=postgres://user:password@localhost:5432/careerhub_db

# ============================================
# FRONTEND (Vite/React) - Place in /frontend/.env
# ============================================
VITE_API_BASE_URL=http://127.0.0.1:8080/api/
